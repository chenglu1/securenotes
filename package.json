{
  "name": "securenotes",
  "version": "1.0.0",
  "main": "dist-electron/main.js",
  "description": "离线优先、支持实时协作、端到端加密的 Markdown 笔记应用",
  "author": "chenglud <chenglud@digitalchina.com>",
  "license": "MIT",
  "private": true,
  "keywords": [
    "electron",
    "markdown",
    "notes",
    "e2e-encryption",
    "crdt",
    "offline-first"
  ],
  "debug": {
    "env": {
      "VITE_DEV_SERVER_URL": "http://127.0.0.1:9999"
    }
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build && electron-builder",
    "preview": "vite preview"
  },
  "devDependencies": {
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^4.7.0",
    "autoprefixer": "^10.4.27",
    "electron": "^28.1.0",
    "electron-builder": "^24.4.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.0.3",
    "vite": "^5.0.10",
    "vite-plugin-electron": "^0.28.8",
    "vite-plugin-electron-renderer": "^0.14.6"
  },
  "dependencies": {
    "@chenglu1/xeditor-editor": "^0.0.8",
    "lucide-react": "^0.575.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sql.js": "^1.14.0",
    "uuid": "^13.0.0",
    "zustand": "^5.0.11"
  }
}
